{
  "npm.scriptRunner": "vp",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.fmt.configPath": "./vite.config.ts",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "files.watcherExclude": {
    "**/tmp/**": true,
    "**/sites/**": true,
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/tmp/**": true,
    "**/sites/**": true,
    "**/node_modules/**": true
  },
  "vitest.rootConfig": "vite.config.ts",
  "vitest.configSearchPatternInclude": "vite.config.ts",
  "vitest.configSearchPatternExclude": "{**/node_modules/**,**/vendor/**,**/.*/**,**/*.d.ts,**/tmp/**,**/sites/**}",
  "vitest.filesWatcherInclude": "{src,lib}/**/*.{test,spec}.{ts,tsx,js,jsx}",
  "vitest.watchOnStartup": false
}
