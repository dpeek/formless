{
  "name": "formless",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "lib/*"
  ],
  "type": "module",
  "scripts": {
    "ralph": "bun run scripts/ralph-loop.ts",
    "browser": "agent-browser",
    "check": "vp check --fix",
    "test": "vp test --reporter=agent",
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "site:pull-seed": "bun run scripts/site-pull-seed.ts",
    "deploy": "vp build && wrangler deploy"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "wouter": "^3.9.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.2",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@formless/ui": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "devstate": "^0.1.6",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "miniflare": "^4.20260424.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^4.85.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.13"
}
