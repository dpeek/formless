{
  "name": "@dpeek/formless",
  "version": "0.1.9",
  "bin": {
    "formless": "bin/formless.js"
  },
  "workspaces": [
    "lib/*"
  ],
  "files": [
    "bin",
    "index.html",
    "README.md",
    "schema",
    "scripts",
    "src",
    "tsconfig.json",
    "vite.config.ts"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "agents": "bun run scripts/agents.ts",
    "browser": "agent-browser",
    "check": "vp check --fix",
    "test": "vp test --dir src --configLoader runner && vp test --dir scripts --configLoader runner",
    "dev": "bun scripts/formless.ts dev --workspace tmp/devstate-workspace --reset",
    "dev:instance": "FORMLESS_RUNTIME_PROFILE=instance VITE_FORMLESS_RUNTIME_PROFILE=instance FORMLESS_LAUNCH_FIXTURE=empty vp dev",
    "dev:instance:empty": "FORMLESS_RUNTIME_PROFILE=instance VITE_FORMLESS_RUNTIME_PROFILE=instance FORMLESS_LAUNCH_FIXTURE=empty vp dev",
    "dev:instance:multi-site": "FORMLESS_RUNTIME_PROFILE=instance VITE_FORMLESS_RUNTIME_PROFILE=instance FORMLESS_LAUNCH_FIXTURE=multi-site vp dev",
    "prepack": "bun run scripts/build-package.ts"
  },
  "dependencies": {
    "@cf-wasm/resvg": "0.3.4",
    "@cloudflare/vite-plugin": "^1.33.2",
    "@dnd-kit/react": "^0.4.0",
    "@dpeek/formless-archive": "^0.1.0",
    "@dpeek/formless-astryx": "workspace:*",
    "@dpeek/formless-crm-app": "^0.1.0",
    "@dpeek/formless-deploy": "^0.1.0",
    "@dpeek/formless-gateway": "^0.1.0",
    "@dpeek/formless-identity-control-plane": "^0.1.0",
    "@dpeek/formless-installed-apps": "^0.1.0",
    "@dpeek/formless-instance-control-plane": "^0.1.0",
    "@dpeek/formless-media": "^0.1.0",
    "@dpeek/formless-public-operations": "^0.1.0",
    "@dpeek/formless-schema": "^0.1.0",
    "@dpeek/formless-site-app": "^0.1.0",
    "@dpeek/formless-storage": "^0.1.0",
    "@dpeek/formless-tasks-app": "^0.1.0",
    "@dpeek/formless-ui": "^0.1.3",
    "@dpeek/formless-workspace": "^0.1.0",
    "@internationalized/date": "^3.12.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.93.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "^4.2.4",
    "vite-plus": "^0.2.1",
    "wouter": "^3.9.0",
    "wrangler": "^4.85.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@fission-ai/openspec": "^1.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "agent-browser": "^0.31.1",
    "devstate": "link:devstate",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "miniflare": "^4.20260424.0",
    "react-test-renderer": "19.2.6",
    "typescript": "~6.0.2",
    "zod": "3.25.76"
  },
  "packageManager": "bun@1.3.14"
}
