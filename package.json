{
  "name": "@dpeek/formless",
  "version": "0.1.9",
  "bin": {
    "formless": "bin/formless.js"
  },
  "workspaces": [
    "lib/*"
  ],
  "files": [
    "bin",
    "index.html",
    "README.md",
    "schema",
    "scripts",
    "src",
    "tsconfig.json",
    "vite.config.ts",
    "wrangler.jsonc"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "agents": "bun run scripts/agents.ts",
    "browser": "agent-browser",
    "check": "vp check --fix",
    "test": "vp test --reporter=agent",
    "dev": "vp dev",
    "dev:instance": "FORMLESS_RUNTIME_PROFILE=instance VITE_FORMLESS_RUNTIME_PROFILE=instance FORMLESS_LAUNCH_FIXTURE=empty vp dev",
    "dev:instance:empty": "FORMLESS_RUNTIME_PROFILE=instance VITE_FORMLESS_RUNTIME_PROFILE=instance FORMLESS_LAUNCH_FIXTURE=empty vp dev",
    "dev:instance:multi-site": "FORMLESS_RUNTIME_PROFILE=instance VITE_FORMLESS_RUNTIME_PROFILE=instance FORMLESS_LAUNCH_FIXTURE=multi-site vp dev",
    "build": "vp build",
    "package:build": "bun run scripts/build-package.ts",
    "prepack": "bun run package:build",
    "preview": "vp preview",
    "formless": "bun run scripts/formless.ts",
    "site:pull-seed": "bun run scripts/site-pull-seed.ts",
    "deploy": "vp build && wrangler deploy"
  },
  "dependencies": {
    "@cf-wasm/resvg": "0.3.4",
    "@cloudflare/vite-plugin": "^1.33.2",
    "@dnd-kit/react": "^0.4.0",
    "@dpeek/formless-deploy": "^0.1.0",
    "@dpeek/formless-gateway": "^0.1.0",
    "@dpeek/formless-media": "^0.1.0",
    "@dpeek/formless-schema": "^0.1.0",
    "@dpeek/formless-ui": "^0.1.3",
    "@internationalized/date": "^3.12.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.93.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wouter": "^3.9.0",
    "wrangler": "^4.85.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "devstate": "^0.1.6",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "miniflare": "^4.20260424.0",
    "typescript": "~6.0.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.13"
}
