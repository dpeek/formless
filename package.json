{
  "name": "@dpeek/formless-monorepo",
  "private": true,
  "workspaces": [
    "lib/*"
  ],
  "type": "module",
  "scripts": {
    "check:setup": "bun install && bun check:packages >/dev/null 2>&1 &",
    "check:openspec": "openspec validate --specs --strict --no-interactive",
    "check:packages": "vp run --recursive check && vp run --workspace-root check",
    "check:ready": "bun check:openspec && bun check:packages",
    "agents": "bun run scripts/agents.ts",
    "check": "vp check --fix scripts && vp test --dir scripts --configLoader runner",
    "dev": "bun lib/formless/bin/formless.ts dev --workspace tmp/dev-workspace --reset",
    "dev:instance": "bun run --cwd lib/formless dev:instance",
    "dev:instance:empty": "bun run --cwd lib/formless dev:instance:empty",
    "dev:instance:multi-site": "bun run --cwd lib/formless dev:instance:multi-site"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.5.0",
    "@types/node": "^25.6.0",
    "agent-browser": "^0.32.3",
    "typescript": "~6.0.2",
    "vite-plus": "^0.2.5"
  },
  "packageManager": "bun@1.3.14"
}
