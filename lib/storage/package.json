{
  "name": "@dpeek/formless-storage",
  "version": "0.1.0",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.*",
    "!src/**/*-fixtures.ts",
    "!src/**/test-*.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    },
    "access": "public"
  },
  "scripts": {
    "check": "vp check --fix && vp test --configLoader runner",
    "pack": "vp pack src/index.ts"
  },
  "dependencies": {
    "@dpeek/formless-schema": "workspace:*"
  }
}
