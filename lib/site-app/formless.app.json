{
  "kind": "formless.appPackage",
  "version": 1,
  "packageAppKey": "site",
  "label": "Site",
  "description": "Public website app backed by the bundled Site schema and starter records.",
  "defaultInstallId": "site",
  "supportsMultipleInstalls": true,
  "packageRevision": 1,
  "sourceSchema": {
    "kind": "bundled",
    "key": "site",
    "path": "schema.json"
  },
  "seedRecords": {
    "kind": "bundled",
    "key": "site",
    "path": "seed-records.json"
  },
  "sourceSchemaHash": "sha256:7ed35b2ad3f7e9c5384f28757f394fad1d736fda67de2e901e2bacaf86c6ad56",
  "capabilities": [
    {
      "kind": "generatedAdmin",
      "routeBase": "/apps"
    },
    {
      "kind": "publicSite",
      "routeBase": "/sites"
    }
  ]
}
