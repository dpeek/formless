{
  "kind": "formless.appPackage",
  "version": 1,
  "packageAppKey": "site",
  "label": "Site",
  "description": "Public website app backed by the bundled Site schema and starter records.",
  "defaultInstallId": "site",
  "supportsMultipleInstalls": true,
  "packageRevision": 1,
  "sourceSchema": {
    "kind": "bundled",
    "key": "site",
    "path": "schema.json"
  },
  "seedRecords": {
    "kind": "bundled",
    "key": "site",
    "path": "seed-records.json"
  },
  "sourceSchemaHash": "sha256:4b2d03317e4bfa73a3375c212220890694c4bb9ff945dd226fb50611c3267a00",
  "capabilities": [
    {
      "kind": "generatedAdmin",
      "routeBase": "/apps"
    },
    {
      "kind": "publicSite",
      "routeBase": "/sites"
    }
  ]
}
