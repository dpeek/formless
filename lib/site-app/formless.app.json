{
  "kind": "formless.appPackage",
  "version": 1,
  "packageAppKey": "site",
  "label": "Site",
  "description": "Public website app backed by the bundled Site schema and starter records.",
  "defaultInstallId": "site",
  "supportsMultipleInstalls": true,
  "packageRevision": 1,
  "sourceSchema": {
    "kind": "bundled",
    "key": "site",
    "path": "schema.json"
  },
  "seedRecords": {
    "kind": "bundled",
    "key": "site",
    "path": "seed-records.json"
  },
  "sourceSchemaHash": "sha256:7ad82a3f1d14ee8f6cd7dc88fba1ec42de061670ea7c419d1140c175ecb6a64b",
  "capabilities": [
    {
      "kind": "generatedAdmin",
      "routeBase": "/apps"
    },
    {
      "kind": "publicSite",
      "routeBase": "/sites"
    }
  ]
}
