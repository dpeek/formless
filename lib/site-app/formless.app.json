{
  "kind": "formless.appPackage",
  "version": 1,
  "packageAppKey": "site",
  "label": "Site",
  "description": "Public website app backed by the bundled Site schema and starter records.",
  "defaultInstallId": "site",
  "supportsMultipleInstalls": true,
  "packageRevision": 1,
  "sourceSchema": {
    "kind": "bundled",
    "key": "site",
    "path": "schema.json"
  },
  "seedRecords": {
    "kind": "bundled",
    "key": "site",
    "path": "seed-records.json"
  },
  "sourceSchemaHash": "sha256:33f3c7f33b41b92904ffb80a3f37e811a2688129b337ed2cdb242e4ae04b6a8e",
  "capabilities": [
    {
      "kind": "generatedAdmin",
      "routeBase": "/apps"
    },
    {
      "kind": "publicSite",
      "routeBase": "/sites"
    }
  ]
}
