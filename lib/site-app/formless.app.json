{
  "kind": "formless.appPackage",
  "version": 1,
  "packageAppKey": "site",
  "label": "Site",
  "description": "Public website app backed by the bundled Site schema and starter records.",
  "defaultInstallId": "site",
  "supportsMultipleInstalls": true,
  "packageRevision": 1,
  "sourceSchema": {
    "kind": "bundled",
    "key": "site",
    "path": "schema.json"
  },
  "seedRecords": {
    "kind": "bundled",
    "key": "site",
    "path": "seed-records.json"
  },
  "sourceSchemaHash": "sha256:af7fe1ba958838a4ba2606f18c1bfaf1906094b48120faf96aeae292d8284e83",
  "capabilities": [
    {
      "kind": "generatedAdmin",
      "routeBase": "/apps"
    },
    {
      "kind": "publicSite",
      "routeBase": "/sites"
    }
  ]
}
