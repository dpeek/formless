{
  "$schema": "https://unpkg.com/devstate/schema/v1.json",
  "setup": {
    "install": {
      "cmd": "bun install"
    }
  },
  "checks": {
    "vite": {
      "cmd": "bun run check"
    }
  },
  "services": {
    "web": {
      "cmd": "portless run -- bun run dev",
      "events": {
        "url": {
          "log": "https?://(?:[a-z0-9-]+\\.)*formless\\.local/api/formless/local-session/bootstrap[^\n]+"
        },
        "ready": {
          "log": "https?://(?:[a-z0-9-]+\\.)*formless\\.local/api/formless/local-session/bootstrap[^\n]+"
        }
      }
    },
    "test": {
      "cmd": "vp test --watch --reporter=agent --no-color",
      "events": {
        "run": {
          "log": "RERUN"
        },
        "fail": {
          "log": "FAIL"
        },
        "pass": {
          "log": "PASS"
        },
        "ready": {
          "log": "(?:(?:Test Files|Tests)\\s+\\d+\\s+passed|PASS\\s+Waiting for file changes)"
        }
      }
    }
  }
}
