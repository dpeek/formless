{
  "$schema": "https://unpkg.com/devstate/schema/v1.json",
  "setup": {
    "install": {
      "cmd": "bun install"
    }
  },
  "checks": {
    "vite": {
      "cmd": "vp check --fix"
    },
    "test": {
      "cmd": "vp run --recursive test"
    }
  },
  "services": {
    "web": {
      "cmd": "portless run -- bun run dev",
      "events": {
        "url": {
          "log": "https?://(?:[a-z0-9-]+\\.)*formless\\.local/api/formless/local-session/bootstrap[^\n]+"
        },
        "ready": {
          "log": "https?://(?:[a-z0-9-]+\\.)*formless\\.local/api/formless/local-session/bootstrap[^\n]+"
        }
      }
    }
  }
}
