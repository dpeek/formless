{
  "version": 1,
  "entities": {
    "task": {
      "label": "Task",
      "fields": {
        "title": {
          "type": "text",
          "required": true,
          "label": "Title"
        },
        "done": {
          "type": "boolean",
          "required": true,
          "label": "Done",
          "default": false
        },
        "dueDate": {
          "type": "date",
          "required": false,
          "label": "Due date"
        }
      },
      "mutations": {
        "create": {
          "enabled": true
        },
        "patch": {
          "enabled": true
        },
        "delete": {
          "enabled": false
        }
      },
      "actions": {
        "clearCompletedTasks": {
          "label": "Clear completed",
          "kind": "clear-completed",
          "target": {
            "query": {
              "kind": "where",
              "ref": {
                "kind": "value",
                "name": "done"
              },
              "op": "eq",
              "value": true
            }
          }
        }
      }
    }
  },
  "views": {
    "taskAll": {
      "type": "list",
      "label": "All",
      "entity": "task",
      "query": {
        "kind": "all"
      },
      "fields": {
        "title": {
          "editor": "text",
          "commit": "field-commit"
        },
        "done": {
          "editor": "boolean",
          "commit": "immediate"
        },
        "dueDate": {
          "editor": "date",
          "commit": "field-commit"
        }
      }
    },
    "taskActive": {
      "type": "list",
      "label": "Active",
      "entity": "task",
      "query": {
        "kind": "where",
        "ref": {
          "kind": "value",
          "name": "done"
        },
        "op": "eq",
        "value": false
      },
      "fields": {
        "title": {
          "editor": "text",
          "commit": "field-commit"
        },
        "done": {
          "editor": "boolean",
          "commit": "immediate"
        },
        "dueDate": {
          "editor": "date",
          "commit": "field-commit"
        }
      }
    },
    "taskCompleted": {
      "type": "list",
      "label": "Completed",
      "entity": "task",
      "query": {
        "kind": "where",
        "ref": {
          "kind": "value",
          "name": "done"
        },
        "op": "eq",
        "value": true
      },
      "fields": {
        "title": {
          "editor": "text",
          "commit": "field-commit"
        },
        "done": {
          "editor": "boolean",
          "commit": "immediate"
        },
        "dueDate": {
          "editor": "date",
          "commit": "field-commit"
        }
      }
    },
    "taskCreate": {
      "type": "create",
      "entity": "task",
      "fields": {
        "title": {
          "editor": "text"
        },
        "dueDate": {
          "editor": "date"
        }
      }
    }
  }
}
