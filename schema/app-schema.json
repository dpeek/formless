{
  "version": 1,
  "entities": {
    "task": {
      "label": "Task",
      "fields": {
        "title": {
          "type": "text",
          "required": true,
          "label": "Title"
        },
        "done": {
          "type": "boolean",
          "required": true,
          "label": "Done",
          "default": false
        },
        "dueDate": {
          "type": "date",
          "required": false,
          "label": "Due date"
        }
      },
      "mutations": {
        "create": {
          "enabled": true
        },
        "patch": {
          "enabled": true
        },
        "delete": {
          "enabled": false
        }
      }
    }
  }
}
