{
  "version": 1,
  "entities": {
    "task": {
      "label": "Task",
      "fields": {
        "title": {
          "type": "text",
          "required": true,
          "label": "Title"
        },
        "done": {
          "type": "boolean",
          "required": true,
          "label": "Done",
          "default": false
        },
        "dueDate": {
          "type": "date",
          "required": false,
          "label": "Due date"
        }
      },
      "mutations": {
        "create": {
          "enabled": true
        },
        "patch": {
          "enabled": true
        },
        "delete": {
          "enabled": false
        }
      }
    }
  },
  "views": {
    "taskListItem": {
      "type": "list",
      "entity": "task",
      "fields": {
        "title": {
          "editor": "text",
          "commit": "field-commit"
        },
        "done": {
          "editor": "boolean",
          "commit": "immediate"
        },
        "dueDate": {
          "editor": "date",
          "commit": "field-commit"
        }
      }
    },
    "taskCreate": {
      "type": "create",
      "entity": "task",
      "fields": {
        "title": {
          "editor": "text"
        },
        "dueDate": {
          "editor": "date"
        }
      }
    }
  }
}
